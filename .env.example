# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# ─────────────────────────────────────────────
# Database (NeonDB)
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/vitals?sslmode=require"

# ─────────────────────────────────────────────
# Redis (Upstash)
# ─────────────────────────────────────────────
UPSTASH_REDIS_URL="rediss://:password@host:6380"
REDIS_HOST="host"
REDIS_PORT=6380
REDIS_PASSWORD="password"
REDIS_TLS=true

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_ACCESS_SECRET="your-access-secret-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─────────────────────────────────────────────
# Email (Brevo / SMTP)
# ─────────────────────────────────────────────
BREVO_SMTP_HOST="smtp-relay.brevo.com"
BREVO_SMTP_PORT=587
BREVO_SMTP_USER="your-brevo-login@email.com"
BREVO_SMTP_PASS="your-brevo-smtp-key"
EMAIL_FROM_ADDRESS="noreply@vitals.health"
EMAIL_FROM_NAME="Vitals"

# ─────────────────────────────────────────────
# App URLs
# ─────────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"
API_URL="http://localhost:3000"

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
CORS_ORIGIN="http://localhost:5173"

# ─────────────────────────────────────────────
# AI (Gemini)
# ─────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"

# ─────────────────────────────────────────────
# Storage (Cloudinary)
# ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─────────────────────────────────────────────
# Firebase FCM (Push Notifications)
# ─────────────────────────────────────────────
# Backend — Firebase Admin SDK credentials (from Firebase Console > Project Settings > Service Accounts)
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com"
# Paste the full private key including -----BEGIN/END----- lines. Keep \n as literal characters.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Frontend — VAPID public key from Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
# Used by the frontend Firebase SDK to generate FCM tokens. NOT used for server-side sending.
VAPID_PUBLIC_KEY="your-vapid-public-key-from-firebase-console"

# ─────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ─────────────────────────────────────────────
# AI Quotas
# ─────────────────────────────────────────────
FREE_SYMPTOM_CHECKS_PER_DAY=3
FREE_DRUG_DETECTIONS_PER_DAY=3
PREMIUM_SYMPTOM_CHECKS_PER_DAY=20
PREMIUM_DRUG_DETECTIONS_PER_DAY=20

# ─────────────────────────────────────────────
# Reminder settings
# ─────────────────────────────────────────────
ADHERENCE_CHECK_DELAY_MS=1800000
MISSED_WINDOW_MS=7200000

# ─────────────────────────────────────────────
# Verification token
# ─────────────────────────────────────────────
EMAIL_VERIFICATION_TOKEN_EXPIRES_HOURS=24
